<Window x:Class="PontenWPF.ImageEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Editor" Height="600" Width="800"
        Icon="pack://application:,,,/Assets/Ponten.ico"
        Background="#1E1E1E" Foreground="White">
    <Grid Margin="10" Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,10,0" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image x:Name="PreviewImage" Stretch="None">
                    <Image.LayoutTransform>
                        <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                    </Image.LayoutTransform>
                </Image>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Column="1" Margin="10,0,0,0">
            <TextBlock Text="Thickness (0-30):"/>
            <Slider x:Name="ThicknessSlider" Minimum="0" Maximum="30" Value="0" ValueChanged="OnSliderValueChanged"/>

            <TextBlock Text="Brightness (-0.5 to 0.5):" Margin="0,10,0,0"/>
            <Slider x:Name="BrightnessSlider" Minimum="-0.5" Maximum="0.5" Value="0" ValueChanged="OnSliderValueChanged"/>

            <TextBlock Text="Contrast (0.5 to 2.0):" Margin="0,10,0,0"/>
            <Slider x:Name="ContrastSlider" Minimum="0.5" Maximum="2.0" Value="1.0" ValueChanged="OnSliderValueChanged"/>

            <TextBlock Text="Zoom (0.5 to 5.0):" Margin="0,10,0,0"/>
            <Slider x:Name="ZoomSlider" Minimum="0.5" Maximum="5.0" Value="1.0" ValueChanged="OnSliderValueChanged"/>

            <TextBlock Text="Rotate (-180 to 180):" Margin="0,10,0,0"/>
            <Slider x:Name="RotateSlider" Minimum="-180" Maximum="180" Value="0" ValueChanged="OnSliderValueChanged"/>

            <CheckBox x:Name="RemoveBgCheckBox" Content="Remove Bg" Margin="0,20,0,0" Checked="OnCheckBoxChanged" Unchecked="OnCheckBoxChanged"/>
            <CheckBox x:Name="AutoTrimCheckBox" Content="Auto-Trim" Margin="0,10,0,0" Checked="OnCheckBoxChanged" Unchecked="OnCheckBoxChanged"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,30,0,0" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Padding="5" Margin="0,0,10,0" Click="CancelButton_Click"/>
                <Button Content="Save" Width="80" Padding="5" Background="#007ACC" Foreground="White" Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
