<Window x:Class="PontenWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PontenWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="450"
        Icon="pack://application:,,,/Assets/Ponten.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True">
    <Grid>
        <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#333333" BorderThickness="1" Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="2" />
            </Border.Effect>
            <StackPanel Margin="20">
                <TextBlock Text="Ponten" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Thickness:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="20" Value="2" Width="100" VerticalAlignment="Center" ValueChanged="ThicknessSlider_ValueChanged"/>
                    <TextBlock Text="Style:" Foreground="LightGray" VerticalAlignment="Center" Margin="20,0,10,0"/>
                    <ComboBox x:Name="StyleComboBox" Width="100" SelectionChanged="StyleComboBox_SelectionChanged">
                        <ComboBoxItem Content="Normal" IsSelected="True"/>
                        <ComboBoxItem Content="Calligraphy"/>
                    </ComboBox>
                </StackPanel>
                <Border BorderBrush="#333333" BorderThickness="1" Height="250" Background="White">
                    <InkCanvas x:Name="SignatureCanvas"/>
                </Border>
                <TextBlock Text="Ready for Phase 3" Foreground="LightGray" FontSize="14" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
