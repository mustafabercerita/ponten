<Window x:Class="PontenWPF.MenuBarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ponten Menu" Height="300" Width="250"
        Icon="pack://application:,,,/Assets/Ponten.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True">
    <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#333333" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="2" />
        </Border.Effect>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Ponten Signatures" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SignaturesList">
                    <!-- Active signatures will go here -->
                    <TextBlock Text="No signatures yet." Foreground="Gray" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </ScrollViewer>
            
            <Button Grid.Row="2" Content="Add Signature" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="5" Margin="0,10,0,0" Click="AddSignature_Click"/>
        </Grid>
    </Border>
</Window>
