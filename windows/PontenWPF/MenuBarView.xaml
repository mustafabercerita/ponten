<Window x:Class="PontenWPF.MenuBarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationFramework"
        Title="Ponten Menu" Height="480" Width="320"
        Icon="pack://application:,,,/Assets/Ponten.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        automation:AutomationProperties.AutomationId="PontenMainWindow">
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#333333" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.5" ShadowDepth="4" />
        </Border.Effect>
        <Grid Margin="15" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Signature List / Main Area -->
                <RowDefinition Height="Auto"/> <!-- Sign Button -->
                <RowDefinition Height="Auto"/> <!-- Toolbar -->
                <RowDefinition Height="Auto"/> <!-- Settings -->
                <RowDefinition Height="*"/>    <!-- Filler -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/Ponten.ico" Width="24" Height="24" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Ponten" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="VersionLabel" Foreground="Gray" FontSize="12" Margin="8,4,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Signature List -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="110" Margin="0,0,0,15">
                <Grid>
                    <TextBlock x:Name="EmptyStateText" Text="No signatures yet." Foreground="Gray" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"
                               automation:AutomationProperties.AutomationId="EmptyState"/>
                    <ListBox x:Name="SignaturesListBox" Background="Transparent" BorderThickness="0" 
                             SelectionChanged="SignaturesListBox_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             automation:AutomationProperties.AutomationId="SignaturesList">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="140">
                                    <Border Background="White" CornerRadius="8" Margin="0,0,10,0" Padding="5" Width="140" Height="90">
                                        <Image Source="{Binding ImageSource}" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#AAAAAA" FontSize="10"
                                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               MaxWidth="130" Margin="0,4,10,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu Background="#2D2D2D" BorderBrush="#444444">
                                            <MenuItem Header="Edit" Foreground="White" Click="EditSignature_Click"/>
                                            <MenuItem Header="Rename" Foreground="White" Click="RenameSignature_Click"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="BorderBrush" Value="#007ACC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </ScrollViewer>
            
            <!-- Sign Button -->
            <Button Grid.Row="2" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,15" Click="SignButton_Click"
                    automation:AutomationProperties.AutomationId="SignButton">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock Text="Sign" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Text="Ctrl+Alt+S" HorizontalAlignment="Right" Foreground="#B3FFFFFF" FontSize="11" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <!-- Toolbar -->
            <Grid Grid.Row="3" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Foreground="White" Background="Transparent" BorderThickness="0" Margin="0,0,10,0" Click="AddSignature_Click"
                        automation:AutomationProperties.AutomationId="AddButton">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"/>
                        <TextBlock Text="Add" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Foreground="White" Background="Transparent" BorderThickness="0" Click="DrawSignature_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"/>
                        <TextBlock Text="Draw" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <CheckBox x:Name="RemoveBgToggle" Content="Remove BG" Foreground="White" IsChecked="True" VerticalAlignment="Center" Margin="5,0,0,0"
                              Checked="RemoveBgToggle_Changed" Unchecked="RemoveBgToggle_Changed"
                              automation:AutomationProperties.AutomationId="RemoveBgToggle"/>
                </StackPanel>
                
                <Button Grid.Column="3" Foreground="#FF4444" Background="Transparent" BorderThickness="0" Click="RemoveSignature_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#FF4444" Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"/>
                        <TextBlock Text="Remove" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
            
            <Separator Grid.Row="4" Background="#333333" Margin="0,0,0,10" VerticalAlignment="Top"/>
            
            <!-- Settings -->
            <StackPanel Grid.Row="4" Margin="0,10,0,0">
                <TextBlock Text="Settings" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <CheckBox x:Name="LaunchAtLoginCheck" Content="Launch at Login" Foreground="LightGray" Margin="0,0,0,8" Click="LaunchAtLoginCheck_Click"
                          automation:AutomationProperties.AutomationId="LaunchAtLoginCheck"/>
                <CheckBox x:Name="AutoPasteCheck" Content="Auto-paste after copying" Foreground="LightGray" Margin="0,0,0,8" Click="AutoPasteCheck_Click"
                          automation:AutomationProperties.AutomationId="AutoPasteCheck"/>
                
                <Grid Margin="0,5,0,0">
                    <TextBlock Text="Global Shortcut" Foreground="LightGray" VerticalAlignment="Center"/>
                    <TextBlock Text="Shortcut: Ctrl+Alt+S" Foreground="#888888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
            
            <!-- Footer -->
            <Grid Grid.Row="6" Margin="0,15,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="StatusText" Grid.Row="0" Text="" Foreground="#4CAF50" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,8" Visibility="Collapsed"
                           automation:AutomationProperties.AutomationId="StatusText"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Check for Updates" Foreground="LightGray" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Click="CheckUpdates_Click"/>
                    <Button Grid.Column="1" Content="Quit" Foreground="LightGray" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Click="Quit_Click"
                            automation:AutomationProperties.AutomationId="QuitButton"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>